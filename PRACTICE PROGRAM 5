#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
int main()
{
    int fd;
    char data[50];

    printf("Enter data: ");
    scanf("%s", data);

    fd = open("data.txt", O_CREAT | O_WRONLY | O_TRUNC, 0644);
    write(fd, data, sizeof(data));
    close(fd);

    fd = open("data.txt", O_RDONLY);
    read(fd, data, sizeof(data));
    close(fd);

    printf("Data read from file: %s\n", data);

    return 0;
}
